{
  "_comment": "Per-repo proje deploy config. enabled:true yapınca ve push'layınca imaj GHCR'a gider, ajan deploy eder. Düz sır yok; secret_names sır ADLARINI işaret eder (değerleri GitHub Secrets'ta).",
  "enabled": false,
  "repo_mode": "per-repo",
  "registry": "ghcr.io/auto-forge-projects",
  "server": "main",
  "domain": "apps.sametemek.com",
  "subdomain": "{project}",
  "proxy": "nginx",
  "port": 3000,
  "host_port": null,
  "env_ref": "github-secrets",
  "secret_names": {
    "host": "DEPLOY_HOST",
    "user": "DEPLOY_USER",
    "key": "DEPLOY_SSH_KEY"
  },
  "tls": "wildcard",
  "cert_base": "/etc/letsencrypt/live/apps.sametemek.com",
  "healthcheck": "/health"
}
